{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Shareland",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://share.land"
  },
  "navbar": {
    "links": [
      {
        "label": "Exchange",
        "href": "https://share.land"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Start Investing",
      "href": "https://share.land"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "guides/introduction",
              "guides/what-is-sqft",
              "guides/how-it-works",
              "guides/supported-markets"
            ]
          }
        ]
      },
      {
        "tab": "How To",
        "groups": [
          {
            "group": "Using the Exchange",
            "pages": [
              "how-to/create-account",
              "how-to/buy-sqft",
              "how-to/sell-sqft",
              "how-to/view-portfolio",
              "how-to/understand-oracle"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Resources",
            "pages": [
              "reference/faq",
              "reference/glossary",
              "reference/regulatory"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Exchange",
          "href": "https://share.land",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Community",
          "href": "https://discord.gg/shareland",
          "icon": "discord"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/shareland",
      "discord": "https://discord.gg/shareland"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}
